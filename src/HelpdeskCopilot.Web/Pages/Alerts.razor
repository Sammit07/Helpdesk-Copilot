@page "/alerts"
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Alerts — Azure Helpdesk Copilot</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Azure Monitor Alerts</h5>
    <div class="d-flex gap-2">
        <select class="form-select form-select-sm" @bind="_statusFilter" @bind:after="LoadAlerts" style="width:160px">
            <option value="">All Status</option>
            @foreach (var s in Enum.GetValues<AlertStatus>())
            {
                <option value="@s">@s</option>
            }
        </select>
        <select class="form-select form-select-sm" @bind="_mockType" style="width:200px">
            @foreach (var t in Enum.GetValues<AlertType>())
            {
                <option value="@t">@t</option>
            }
        </select>
        <button class="btn btn-sm btn-danger" @onclick="SimulateAlert" disabled="@_loading">
            <i class="bi bi-lightning-charge-fill me-1"></i>Simulate Alert
        </button>
        <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAlerts">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_successMsg))
{
    <div class="alert alert-success alert-dismissible py-2">
        @_successMsg
        <button type="button" class="btn-close" @onclick='() => _successMsg = ""'></button>
    </div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div><p class="mt-2 text-muted">Loading alerts…</p></div>
}
else if (_alerts.Count == 0)
{
    <div class="text-center py-5">
        <i class="bi bi-check-circle display-3 text-success"></i>
        <h5 class="mt-3">No alerts found</h5>
        <p class="text-muted">Simulate one to see the copilot in action</p>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Severity</th>
                            <th>Title</th>
                            <th>Service</th>
                            <th>Triggered</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var alert in _alerts)
                        {
                            <tr>
                                <td><span class="badge @SeverityBadge(alert.Severity)">@alert.Severity</span></td>
                                <td>
                                    <div class="fw-semibold">@alert.Title</div>
                                    <small class="text-muted text-truncate d-block" style="max-width:300px">@alert.Description</small>
                                </td>
                                <td><span class="text-nowrap">@alert.AffectedService</span></td>
                                <td><small class="text-muted text-nowrap">@TimeAgo(alert.TriggeredAt)</small></td>
                                <td><span class="badge @StatusBadge(alert.Status)">@alert.Status</span></td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" @onclick="() => AnalyzeAlert(alert)" title="AI Analyze">
                                            <i class="bi bi-cpu"></i>
                                        </button>
                                        <button class="btn btn-outline-success" @onclick="() => CreateTicket(alert)"
                                                title="Create Ticket" disabled="@(alert.TicketId.HasValue)">
                                            <i class="bi bi-ticket-detailed@(alert.TicketId.HasValue ? "-fill" : "")"></i>
                                        </button>
                                        <button class="btn btn-outline-info" @onclick="() => ViewLogs(alert)" title="View Logs">
                                            <i class="bi bi-journal-text"></i>
                                        </button>
                                        <button class="btn btn-outline-secondary" @onclick="() => OpenChat(alert)" title="Ask AI">
                                            <i class="bi bi-chat-dots"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            @if (_expandedAlertId == alert.Id)
                            {
                                <tr class="table-light">
                                    <td colspan="6" class="p-3">
                                        @if (_analysisLoading)
                                        {
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="spinner-border spinner-border-sm text-primary"></div>
                                                <span>Analyzing with AI…</span>
                                            </div>
                                        }
                                        else if (!string.IsNullOrEmpty(_expandedContent))
                                        {
                                            <div class="expanded-panel">
                                                <h6 class="text-primary mb-2">
                                                    <i class="bi bi-cpu me-1"></i>@_expandedTitle
                                                </h6>
                                                <pre class="analysis-text">@_expandedContent</pre>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private List<Alert> _alerts = [];
    private bool _loading = true;
    private bool _analysisLoading;
    private string _statusFilter = "";
    private AlertType _mockType = AlertType.FailedRequests;
    private Guid? _expandedAlertId;
    private string _expandedContent = string.Empty;
    private string _expandedTitle = string.Empty;
    private string _successMsg = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadAlerts();

    private async Task LoadAlerts()
    {
        _loading = true;
        AlertStatus? filter = Enum.TryParse<AlertStatus>(_statusFilter, out var s) ? s : null;
        try { _alerts = await Api.GetAlertsAsync(filter) ?? []; }
        catch { }
        finally { _loading = false; }
    }

    private async Task AnalyzeAlert(Alert alert)
    {
        if (_expandedAlertId == alert.Id && _expandedTitle == "AI Analysis")
        {
            _expandedAlertId = null; return;
        }
        _expandedAlertId = alert.Id;
        _expandedTitle = "AI Analysis";
        _expandedContent = string.Empty;
        _analysisLoading = true;
        try
        {
            await Api.AnalyzeAlertAsync(alert.Id);
            var updated = await Api.GetAlertAsync(alert.Id);
            _expandedContent = updated?.AiAnalysis ?? "Analysis not available.";
            var idx = _alerts.FindIndex(a => a.Id == alert.Id);
            if (idx >= 0 && updated != null) _alerts[idx] = updated;
        }
        catch (Exception ex) { _expandedContent = $"Analysis failed: {ex.Message}"; }
        finally { _analysisLoading = false; }
    }

    private async Task CreateTicket(Alert alert)
    {
        try
        {
            var ticket = await Api.CreateTicketFromAlertAsync(alert.Id);
            _successMsg = $"Ticket created: {ticket?.Title}";
            await LoadAlerts();
        }
        catch (Exception ex) { _successMsg = $"Failed: {ex.Message}"; }
    }

    private async Task ViewLogs(Alert alert)
    {
        if (_expandedAlertId == alert.Id && _expandedTitle == "Log Analysis")
        {
            _expandedAlertId = null; return;
        }
        _expandedAlertId = alert.Id;
        _expandedTitle = "Log Analysis";
        _expandedContent = string.Empty;
        _analysisLoading = true;
        try
        {
            var logs = await Api.GetAlertLogsAsync(alert.Id);
            if (logs != null)
            {
                _expandedContent = $"KQL: {logs.Query}\n\n{logs.Summary}\n\nTop Events ({logs.TotalEvents} total):\n";
                foreach (var e in logs.Entries.Take(5))
                    _expandedContent += $"\n[{e.Timestamp:HH:mm:ss}] {e.Level} | {e.Source} | {e.Message} (×{e.Count})";
            }
        }
        catch (Exception ex) { _expandedContent = $"Log fetch failed: {ex.Message}"; }
        finally { _analysisLoading = false; }
    }

    private async Task SimulateAlert()
    {
        try
        {
            var alert = await Api.GenerateMockAlertAsync(_mockType);
            _successMsg = $"Alert simulated: {alert?.Title}";
            await LoadAlerts();
        }
        catch (Exception ex) { _successMsg = $"Failed: {ex.Message}"; }
    }

    private void OpenChat(Alert alert) =>
        Nav.NavigateTo($"/chat?alertId={alert.Id}");

    private static string SeverityBadge(AlertSeverity s) => s switch
    {
        AlertSeverity.Critical => "severity-critical",
        AlertSeverity.High => "severity-high",
        AlertSeverity.Medium => "severity-medium",
        _ => "severity-low"
    };

    private static string StatusBadge(AlertStatus s) => s switch
    {
        AlertStatus.New => "bg-danger",
        AlertStatus.Acknowledged => "bg-warning text-dark",
        AlertStatus.InProgress => "bg-primary",
        _ => "bg-success"
    };

    private static string TimeAgo(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return dt.ToString("MMM d HH:mm");
    }
}
